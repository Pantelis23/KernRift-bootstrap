// Built-in host function parsing + compilation test.

fn hello() {
    uint64 msg = "Hello from KernRift\n"
    write(1, msg, 20)
}

fn do_alloc() -> uint64 {
    uint64 ptr = alloc(4096)
    return ptr
}

fn do_free(uint64 ptr) {
    dealloc(ptr, 4096)
}

fn get_home() -> uint64 {
    uint64 home = getenv("HOME")
    return home
}

fn run_cmd() -> uint32 {
    uint32 rc = exec("echo hello")
    return rc
}

fn measure_string(uint64 s) -> uint64 {
    uint64 len = str_len(s)
    return len
}

fn copy_string(uint64 dst, uint64 src) -> uint64 {
    uint64 end = str_copy(dst, src)
    return end
}

fn append_string(uint64 dst, uint64 src) -> uint64 {
    uint64 end = str_cat(dst, src)
    return end
}

fn quit(uint32 code) {
    exit(code)
}

fn open_and_close() {
    uint64 fd = file_open("/tmp/test.txt", 1)
    file_close(fd)
}

fn read_file(uint64 fd) -> uint64 {
    uint64 buf = alloc(4096)
    uint64 n = file_read(fd, buf, 4096)
    return n
}

fn write_file(uint64 fd, uint64 buf, uint64 len) -> uint64 {
    uint64 n = file_write(fd, buf, len)
    return n
}

fn get_size(uint64 fd) -> uint64 {
    uint64 sz = file_size(fd)
    return sz
}
