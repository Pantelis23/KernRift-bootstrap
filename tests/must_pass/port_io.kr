// Port I/O intrinsic parsing + compilation test (x86_64).

fn read_keyboard_scancode() -> uint8 {
    uint8 sc = inb(0x60)
    return sc
}

fn write_serial(uint8 ch) {
    outb(0x3F8, ch)
}

fn read_pci_config() -> uint32 {
    outd(0xCF8, 0x80000000)
    uint32 val = ind(0xCFC)
    return val
}

fn read_timer_count() -> uint16 {
    uint16 count = inw(0x40)
    return count
}

fn write_timer_mode(uint16 mode) {
    outw(0x43, mode)
}
