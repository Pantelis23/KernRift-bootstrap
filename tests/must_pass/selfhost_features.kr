#lang experimental

struct Token {
    uint32 kind
    uint64 start
    uint64 len
}

fn test_else_if(uint64 x) -> uint64 {
    if x == 1 { return 10 }
    else if x == 2 { return 20 }
    else { return 30 }
}

fn test_logical_and(uint64 a, uint64 b) -> uint64 {
    uint64 result = 0
    if a != 0 && b != 0 {
        result = 1
    }
    return result
}

fn test_logical_or(uint64 a, uint64 b) -> uint64 {
    uint64 result = 0
    if a != 0 || b != 0 {
        result = 1
    }
    return result
}

fn test_char() -> uint8 {
    uint8 ch = 'A'
    return ch
}

fn test_struct_param(Token t) -> uint32 {
    uint32 k = t.kind
    return k
}
