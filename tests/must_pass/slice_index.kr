// A prototype LZSS / Sliding Window match copier to stress-test KernRift.
// We are testing array indexing, looping, and bitwise operations.

@ctx(thread)
fn copy_match([uint8] out_buf, uint64 dst_pos, uint64 src_pos, uint64 length) -> uint64 {
    uint64 i = 0
    while i < length {
        // Test 1: Does the compiler support slice indexing syntax `out_buf[index]`?
        uint8 b = out_buf[src_pos + i]
        out_buf[dst_pos + i] = b
        i += 1
    }
    
    uint64 new_pos = dst_pos + length
    return new_pos
}

@ctx(thread)
fn read_bit([uint8] in_buf, uint64 bit_offset) -> uint8 {
    uint64 byte_idx = bit_offset / 8
    uint64 bit_idx  = bit_offset % 8
    
    // Test 2: Bitwise shift and mask
    uint8 b = in_buf[byte_idx]
    uint8 shifted = b >> bit_idx
    uint8 result = shifted & 1
    
    return result
}
