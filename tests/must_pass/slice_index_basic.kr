// tests/must_pass/slice_index_basic.kr

fn sum_bytes([uint8] data) -> uint64 {
    uint64 total = 0
    uint64 i = 0
    uint64 len = data.len
    while i < len {
        uint8 b = data[i]
        total = total + b
        i = i + 1
    }
    return total
}

fn zero_fill([uint8] buf, uint64 count) {
    uint64 i = 0
    while i < count {
        buf[i] = 0
        i = i + 1
    }
}
