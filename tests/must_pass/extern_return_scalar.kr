@ctx(irq, thread, boot)
@eff(mmio)
@caps()
extern fn ext_read_reg() -> u64;

@ctx(irq, thread, boot)
@eff(mmio)
@caps()
extern fn host_log(u64 v);

@ctx(irq, thread, boot)
@eff(mmio)
@caps()
fn forward_status() {
    host_log(ext_read_reg())
}

@ctx(thread, boot)
fn entry() {
    forward_status()
}
