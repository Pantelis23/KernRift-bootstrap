// tests/must_pass/arrays.kr — fixed-size local array declarations

@ctx(thread)
fn fill_and_sum() -> uint64 {
    uint8[10] buf
    uint64 i = 0
    while i < 10 {
        buf[i] = i + 1
        i = i + 1
    }
    uint64 total = 0
    i = 0
    while i < 10 {
        uint8 b = buf[i]
        total = total + b
        i = i + 1
    }
    return total
}

@ctx(thread)
fn string_buffer() -> uint8 {
    uint8[64] str
    str[0] = 72
    str[1] = 105
    str[2] = 0
    uint8 first = str[0]
    return first
}

@ctx(thread)
fn uint32_array() -> uint32 {
    uint32[8] arr
    arr[0] = 100
    arr[1] = 200
    arr[2] = 300
    uint32 a = arr[0]
    uint32 b = arr[1]
    uint32 c = arr[2]
    uint32 sum = a + b + c
    return sum
}
