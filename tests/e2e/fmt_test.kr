// End-to-end test for string formatting built-in functions.
// Exercises: fmt_uint, fmt_hex, fmt_int.
// Expected output: "12345\nff\n42\n"

fn fmt_and_print(uint64 buf, uint64 nl, uint64 len) {
    write(1, buf, len)
    write(1, nl, 1)
}

fn main() {
    uint64 buf = alloc(64)
    uint64 nl = alloc(4)
    str_copy(nl, "\n")

    uint64 len = fmt_uint(buf, 12345)
    fmt_and_print(buf, nl, len)

    len = fmt_hex(buf, 255)
    fmt_and_print(buf, nl, len)

    len = fmt_int(buf, 42)
    fmt_and_print(buf, nl, len)

    exit(0)
}
