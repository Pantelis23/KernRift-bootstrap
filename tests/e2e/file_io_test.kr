// End-to-end test for file I/O built-in functions.
// Writes a file, reads it back, prints the content to stdout.
// Expected output: "hello from kernrift\n"

fn main() {
    // Write a file
    uint64 fd = file_open("/tmp/kr_fileio_test.txt", 1)
    uint64 msg = "hello from kernrift\n"
    file_write(fd, msg, 20)
    file_close(fd)

    // Read it back
    uint8[64] buf
    uint64 fd2 = file_open("/tmp/kr_fileio_test.txt", 0)
    uint64 n = file_read(fd2, buf, 64)
    file_close(fd2)

    // Write the read content to stdout
    write(1, buf, n)
    exit(0)
}
