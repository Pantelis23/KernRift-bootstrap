{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_verify_artifact_meta_v2.schema.json",
  "title": "kernrift_verify_artifact_meta_v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "file", "result", "exit_code", "message"],
  "properties": {
    "schema_version": { "const": "kernrift_verify_artifact_meta_v2" },
    "file": { "type": "string" },
    "result": {
      "type": "string",
      "enum": ["pass", "mismatch", "invalid_input"]
    },
    "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
    "message": { "type": "string" }
  }
}
