{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_contracts_v2.schema.json",
  "title": "KernRift Contracts v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capabilities",
    "facts",
    "lockgraph",
    "report"
  ],
  "properties": {
    "schema_version": {
      "const": "kernrift_contracts_v2"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "module_caps",
        "symbols"
      ],
      "properties": {
        "module_caps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "symbols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability_symbol"
          }
        }
      }
    },
    "facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbols"
      ],
      "properties": {
        "symbols": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fact_symbol"
          }
        }
      }
    },
    "lockgraph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edges",
        "max_lock_depth"
      ],
      "properties": {
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lock_edge"
          }
        },
        "max_lock_depth": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_lock_depth",
        "no_yield_spans",
        "effects",
        "critical"
      ],
      "properties": {
        "max_lock_depth": {
          "type": "integer",
          "minimum": 0
        },
        "no_yield_spans": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "integer",
                "minimum": 0
              },
              {
                "type": "string",
                "const": "unbounded"
              }
            ]
          }
        },
        "effects": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "yield_sites_count",
            "alloc_sites_count",
            "block_sites_count",
            "raw_mmio_sites_count"
          ],
          "properties": {
            "yield_sites_count": {
              "type": "integer",
              "minimum": 0
            },
            "alloc_sites_count": {
              "type": "integer",
              "minimum": 0
            },
            "block_sites_count": {
              "type": "integer",
              "minimum": 0
            },
            "raw_mmio_sites_count": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "critical": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "depth_max",
            "violations"
          ],
          "properties": {
            "depth_max": {
              "type": "integer",
              "minimum": 0
            },
            "violations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/critical_violation"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "context": {
      "type": "string",
      "enum": [
        "boot",
        "irq",
        "nmi",
        "thread"
      ]
    },
    "effect": {
      "type": "string",
      "enum": [
        "alloc",
        "block",
        "dma_map",
        "ioport",
        "mmio",
        "preempt_off",
        "yield"
      ]
    },
    "attrs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noyield",
        "critical",
        "leaf",
        "hotpath",
        "lock_budget"
      ],
      "properties": {
        "noyield": {
          "type": "boolean"
        },
        "critical": {
          "type": "boolean"
        },
        "leaf": {
          "type": "boolean"
        },
        "hotpath": {
          "type": "boolean"
        },
        "lock_budget": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "capability_symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "caps_req"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "caps_req": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "fact_symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "is_extern",
        "ctx_ok",
        "ctx_reachable",
        "ctx_provenance",
        "ctx_path_provenance",
        "eff_used",
        "eff_transitive",
        "eff_provenance",
        "raw_mmio_used",
        "raw_mmio_sites_count",
        "caps_req",
        "caps_transitive",
        "caps_provenance",
        "attrs"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "is_extern": {
          "type": "boolean"
        },
        "ctx_ok": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context"
          },
          "uniqueItems": true
        },
        "ctx_reachable": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context"
          },
          "uniqueItems": true
        },
        "ctx_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context_provenance"
          }
        },
        "ctx_path_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/context_path_provenance"
          }
        },
        "eff_used": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          },
          "uniqueItems": true
        },
        "eff_transitive": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          },
          "uniqueItems": true
        },
        "eff_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect_provenance"
          }
        },
        "raw_mmio_used": {
          "type": "boolean"
        },
        "raw_mmio_sites_count": {
          "type": "integer",
          "minimum": 0
        },
        "caps_req": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "caps_transitive": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "caps_provenance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/capability_provenance"
          }
        },
        "attrs": {
          "$ref": "#/$defs/attrs"
        }
      }
    },
    "effect_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect",
        "provenance"
      ],
      "properties": {
        "effect": {
          "$ref": "#/$defs/effect"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "context_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ctx",
        "sources"
      ],
      "properties": {
        "ctx": {
          "$ref": "#/$defs/context"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "context_path_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ctx",
        "path"
      ],
      "properties": {
        "ctx": {
          "$ref": "#/$defs/context"
        },
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "capability_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capability",
        "provenance"
      ],
      "properties": {
        "capability": {
          "type": "string"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "direct",
        "via_callee",
        "via_extern"
      ],
      "properties": {
        "direct": {
          "type": "boolean"
        },
        "via_callee": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "via_extern": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "lock_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      }
    },
    "critical_violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "function",
        "effect",
        "provenance"
      ],
      "properties": {
        "function": {
          "type": "string"
        },
        "effect": {
          "enum": [
            "alloc",
            "block",
            "yield"
          ]
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      }
    }
  }
}
