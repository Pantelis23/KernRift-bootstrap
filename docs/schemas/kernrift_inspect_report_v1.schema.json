{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_inspect_report_v1.schema.json",
  "title": "KernRift Inspect Report v1",
  "description": "Decoded verify-report inspection payload emitted by `kernriftc inspect-report --format json`.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "file",
    "report_schema_version",
    "result",
    "inputs",
    "hash",
    "contracts",
    "signature",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "description": "Inspect-report JSON schema identifier.",
      "const": "kernrift_inspect_report_v1"
    },
    "file": {
      "description": "Exact verify-report file path as provided to the CLI.",
      "type": "string"
    },
    "report_schema_version": {
      "description": "Embedded verify-report schema identifier observed in the decoded report.",
      "type": "string",
      "const": "kernrift_verify_report_v1"
    },
    "result": {
      "description": "Final verify verdict from the decoded report.",
      "type": "string",
      "enum": ["pass", "deny", "invalid_input"]
    },
    "inputs": {
      "description": "Input filenames recorded inside the decoded verify report.",
      "type": "object",
      "additionalProperties": false,
      "required": ["contracts", "hash", "sig", "pubkey"],
      "properties": {
        "contracts": { "type": "string" },
        "hash": { "type": "string" },
        "sig": { "type": ["string", "null"] },
        "pubkey": { "type": ["string", "null"] }
      }
    },
    "hash": {
      "description": "Hash comparison facts from the decoded verify report.",
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_sha256", "computed_sha256", "matched"],
      "properties": {
        "expected_sha256": { "type": ["string", "null"] },
        "computed_sha256": { "type": ["string", "null"] },
        "matched": { "type": "boolean" }
      }
    },
    "contracts": {
      "description": "Contracts decode/validation facts from the decoded verify report.",
      "type": "object",
      "additionalProperties": false,
      "required": ["utf8_valid", "schema_valid", "schema_version"],
      "properties": {
        "utf8_valid": { "type": "boolean" },
        "schema_valid": { "type": "boolean" },
        "schema_version": { "type": ["string", "null"] }
      }
    },
    "signature": {
      "description": "Signature-check facts from the decoded verify report.",
      "type": "object",
      "additionalProperties": false,
      "required": ["checked", "valid"],
      "properties": {
        "checked": { "type": "boolean" },
        "valid": { "type": ["boolean", "null"] }
      }
    },
    "diagnostics": {
      "description": "Deterministic sorted+deduped diagnostic messages from the decoded verify report.",
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  }
}
