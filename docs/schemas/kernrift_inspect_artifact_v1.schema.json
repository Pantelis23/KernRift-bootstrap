{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_inspect_artifact_v1.schema.json",
  "title": "kernrift_inspect_artifact_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "file_size",
    "symbols",
    "defined_symbols",
    "undefined_symbols",
    "relocations",
    "flags"
  ],
  "properties": {
    "schema_version": { "const": "kernrift_inspect_artifact_v1" },
    "artifact_kind": { "type": "string" },
    "file_size": { "type": "integer", "minimum": 0 },
    "machine": { "type": "string" },
    "pointer_bits": { "type": "integer", "minimum": 0 },
    "endianness": { "type": "string" },
    "symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "category", "definition"],
        "properties": {
          "name": { "type": "string" },
          "category": { "type": "string" },
          "definition": { "type": "string" }
        }
      }
    },
    "defined_symbols": {
      "type": "array",
      "items": { "type": "string" }
    },
    "undefined_symbols": {
      "type": "array",
      "items": { "type": "string" }
    },
    "relocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "type", "target"],
        "properties": {
          "section": { "type": "string" },
          "type": { "type": "string" },
          "target": { "type": "string" }
        }
      }
    },
    "asm": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "globals",
        "labels",
        "direct_call_targets",
        "appears_x86_64_text_subset"
      ],
      "properties": {
        "globals": { "type": "array", "items": { "type": "string" } },
        "labels": { "type": "array", "items": { "type": "string" } },
        "direct_call_targets": { "type": "array", "items": { "type": "string" } },
        "appears_x86_64_text_subset": { "type": "boolean" }
      }
    },
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "has_entry_symbol",
        "has_undefined_symbols",
        "has_text_relocations"
      ],
      "properties": {
        "has_entry_symbol": { "type": "boolean" },
        "has_undefined_symbols": { "type": "boolean" },
        "has_text_relocations": { "type": "boolean" }
      }
    }
  }
}
