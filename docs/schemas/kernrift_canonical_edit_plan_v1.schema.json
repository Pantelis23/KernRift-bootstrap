{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernrift.dev/schemas/kernrift_canonical_edit_plan_v1.schema.json",
  "title": "kernrift canonical edit plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "surface",
    "edits_count",
    "edits"
  ],
  "properties": {
    "schema_version": {
      "const": "kernrift_canonical_edit_plan_v1"
    },
    "surface": {
      "enum": ["stable", "experimental"]
    },
    "edits_count": {
      "type": "integer",
      "minimum": 0
    },
    "edits": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "function",
          "classification",
          "surface_form",
          "canonical_replacement",
          "migration_safe",
          "rewrite_intent"
        ],
        "properties": {
          "function": {
            "type": "string",
            "minLength": 1
          },
          "classification": {
            "enum": ["compatibility_alias", "deprecated_alias"]
          },
          "surface_form": {
            "type": "string",
            "pattern": "^@"
          },
          "canonical_replacement": {
            "type": "string",
            "minLength": 1
          },
          "migration_safe": {
            "type": "boolean"
          },
          "rewrite_intent": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
